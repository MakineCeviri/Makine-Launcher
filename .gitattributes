# Auto detect text files and perform LF normalization
* text=auto eol=lf

# ============================================
# Binary files
# ============================================

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.bmp binary
*.webp binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# Archives
*.zip binary
*.7z binary
*.tar binary
*.tar.gz binary
*.rar binary

# Executables and libraries
*.exe binary
*.dll binary
*.lib binary
*.a binary
*.so binary
*.dylib binary

# Qt/QML compiled
*.qmlc binary
*.jsc binary

# Translation packages
*.o7 binary

# ============================================
# Source files (force LF)
# ============================================

# C/C++
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.cc text eol=lf
*.hh text eol=lf
*.cxx text eol=lf
*.hxx text eol=lf
*.inl text eol=lf

# Qt/QML
*.qml text eol=lf
*.qrc text eol=lf
*.ui text eol=lf
*.ts text eol=lf

# Build files
CMakeLists.txt text eol=lf
*.cmake text eol=lf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.xml text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Scripts (LF)
*.sh text eol=lf
*.py text eol=lf

# ============================================
# Windows specific (force CRLF)
# ============================================
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.sln text eol=crlf
*.vcxproj text eol=crlf

# ============================================
# Exclude from export
# ============================================
.gitattributes export-ignore
.gitignore export-ignore
.github export-ignore

# ============================================
# Diff settings
# ============================================
*.cpp diff=cpp
*.hpp diff=cpp
*.h diff=cpp
*.qml diff=cpp
