# Makine-Launcher Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.

# --- Cloudflare (R2 CDN access) ---
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# --- Sentry Crash Reporting (DE region) ---
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=makine-ceviri
SENTRY_PROJECT=native
SENTRY_REGION=de

# Sentry DSN (used at build time via CMake, see SEC-13)
MAKINE_SENTRY_DSN=your_sentry_dsn_url

# --- Railway (bot deployment) ---
RAILWAY_TOKEN=your_railway_token

# --- Discord Bot ---
DISCORD_TOKEN=your_discord_bot_token

# --- AI Worker (Cloudflare Workers AI) ---
AI_WORKER_SECRET=your_ai_worker_secret

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key

# --- Notes ---
# encryption_key.h: Required for package encryption/decryption.
#   This file is NOT in the repo. Generate or obtain it separately.
#   Expected location: core/include/makine/encryption_key.h
#   Format: static constexpr array with the encryption key bytes.
